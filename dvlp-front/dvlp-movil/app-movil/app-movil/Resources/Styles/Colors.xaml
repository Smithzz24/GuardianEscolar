<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Colores principales Guardian Escolar -->
    <Color x:Key="Primary">#1A56DB</Color>
    <Color x:Key="PrimaryDark">#003AB8</Color>
    <Color x:Key="PrimaryLight">#2061EC</Color>

    <Color x:Key="Background">#F0F4F8</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardSecondaryBackground">#FFFFFF</Color>

    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="TitleColor">#1A2E4A</Color>

    <Color x:Key="InputPlaceholder">#858E9B</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>

    <Color x:Key="IconColor">#164BB4</Color>
    <Color x:Key="IconBorder">#001C41</Color>

    <Color x:Key="ButtonPrimary">#1A56DB</Color>
    <Color x:Key="ButtonCancel">#FFFFFF</Color>

    <Color x:Key="AlertBackground">#FEF2F2</Color>
    <Color x:Key="AlertTitle">#7F1D1D</Color>
    <Color x:Key="AlertText">#374151</Color>
    <Color x:Key="AlertIcon">#DC2626</Color>

    <!-- Colores base MAUI requeridos -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Secondary">#1A56DB</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="SecondaryDarkText">#FFFFFF</Color>
    <Color x:Key="MidnightBlue">#1A2E4A</Color>
    <Color x:Key="Magenta">#1A56DB</Color>

</ResourceDictionary>