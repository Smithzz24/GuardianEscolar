<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:app_movil.Services"
             x:Class="app_movil.Pages.Auth.VerifyCode"
             BackgroundColor="{StaticResource Background}">


    <VerticalStackLayout
        Padding="30"
        Spacing="10">


        <BoxView
            HeightRequest="1"
            BackgroundColor="{StaticResource BorderColor}"
            HorizontalOptions="FillAndExpand"
            Margin="-30,-30,-30,15"/>

        <Label
            Text="{services:Translation Key=ResetPassword}"
            FontSize="25"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="{StaticResource TitleColor}"
            Margin="0,30,0,0"/>

        <Label
            Text="{services:Translation Key=CodeEmail}"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            FontSize="13"
            TextColor="{StaticResource TextSecondary}"
            Margin="0,0,0,0"/>


        <HorizontalStackLayout 
                HorizontalOptions="Center"
                Spacing="10">
            <Entry
                    BackgroundColor="{StaticResource Background}"
                    WidthRequest="45"
                    HeightRequest="55"
                    MaxLength="1"
                    Keyboard="Numeric"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>
            <Entry
                    BackgroundColor="{StaticResource Background}"
                    WidthRequest="45"
                    HeightRequest="55"
                    MaxLength="1"
                    Keyboard="Numeric"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>
            <Entry
                    BackgroundColor="{StaticResource Background}"
                    WidthRequest="45"
                    HeightRequest="55"
                    MaxLength="1"
                    Keyboard="Numeric"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>
            <Entry
                    BackgroundColor="{StaticResource Background}"
                    WidthRequest="45"
                    HeightRequest="55"
                    MaxLength="1"
                    Keyboard="Numeric"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>
            <Entry
                    BackgroundColor="{StaticResource Background}"
                    WidthRequest="45"
                    HeightRequest="55"
                    MaxLength="1"
                    Keyboard="Numeric"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>
            <Entry
                    BackgroundColor="{StaticResource Background}"
                    WidthRequest="45"
                    HeightRequest="55"
                    MaxLength="1"
                    Keyboard="Numeric"
                    HorizontalTextAlignment="Center"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>

        </HorizontalStackLayout>

            <Label
                 Text="{services:Translation Key=TranferCode}"  
                 HorizontalOptions="Center"
                 HorizontalTextAlignment="Center"
                 TextColor="{StaticResource TitleColor}"
            />
    </VerticalStackLayout>

</ContentPage>